CovenantsWebApp/Bin/Covenants.BLL.pdb
CovenantsWebApp/Bin/Covenants.Scheduler.dll
CovenantsWebApp/Bin/Covenants.Scheduler.pdb

# -----------------------------------------------
# NuGet packages (105 MB — restore from packages.config)
# -----------------------------------------------
packages/
!packages/repositories.config

# -----------------------------------------------
# ASP.NET temp / compiled output
# -----------------------------------------------
CovenantsWebApp/App_Data/*.mdf
CovenantsWebApp/App_Data/*.ldf
CovenantsWebApp/App_Data/*.sdf

